{
  "name": "vue3-echarts-charts",
  "version": "0.0.4",
  "type": "module",
  "description": "A Vue 3 chart component library based on ECharts 6.0, compatible with Windows 7",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "build:lib": "vite build --mode library",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.ts,.tsx,.cts,.mts",
    "lint:fix": "eslint . --ext .vue,.js,.jsx,.cjs,.ts,.tsx,.cts,.mts --fix",
    "type-check": "vue-tsc --noEmit",
    "prepare": "husky install"
  },
  "lint-staged": {
    "*.{vue,ts,tsx,js,jsx,cjs,mts,cts}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.json": [
      "prettier --write"
    ]
  },
  "keywords": [
    "vue3",
    "echarts",
    "charts",
    "vue-echarts",
    "vue-chart",
    "dataviz"
  ],
  "author": "liwh",
  "license": "MIT",
  "peerDependencies": {
    "echarts": "^6.0.0",
    "vue": "^3.2.0"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitejs/plugin-vue": "^4.5.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "echarts": "^6.0.0",
    "eslint": "^10.3.0",
    "eslint-plugin-vue": "^10.9.1",
    "husky": "^4.3.8",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitepress": "^1.0.0",
    "vue": "^3.3.0",
    "vue-tsc": "^1.8.0"
  },
  "dependencies": {
    "lodash-es": "^4.18.1"
  }
}
